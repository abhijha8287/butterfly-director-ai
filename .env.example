# Postgres (used by docker-compose to provision the database container)
POSTGRES_USER=butterfly
POSTGRES_PASSWORD=butterfly
POSTGRES_DB=butterfly_director

# App
APP_NAME=Butterfly Director AI
ENV=development
DEBUG=true
API_V1_PREFIX=/v1

# Auth (kept modular and disabled per the approved hackathon scope)
SECRET_KEY=change-me-to-a-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_ENABLED=false

# Database (docker-compose overrides these to point at the postgres service;
# only used directly if you run the API outside docker-compose)
DATABASE_URL=postgresql+asyncpg://butterfly:butterfly@localhost:5432/butterfly_director
DATABASE_URL_SYNC=postgresql+psycopg://butterfly:butterfly@localhost:5432/butterfly_director

# Redis / Celery (docker-compose overrides these to point at the redis service)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS - comma-separated origins allowed to call the API from a browser
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Rate limiting
RATE_LIMIT_PER_MINUTE=120

# DashScope (Alibaba Cloud Model Studio) - one account key covers Qwen, Wan, and
# CosyVoice. Get yours from the Model Studio console (international workspace).
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com
DASHSCOPE_WS_BASE_URL=wss://dashscope-intl.aliyuncs.com
QWEN_MODEL=qwen-plus
WAN_MODEL=wan2.6-t2v
WAN_VIDEO_SIZE=1280*720
WAN_VIDEO_DURATION_SECONDS=5
COSYVOICE_MODEL=cosyvoice-v3-flash
COSYVOICE_DEFAULT_VOICE=longanyang

# Provider selection (Strategy pattern) - swap which vendor backs each capability
# without touching agent/service code. See app/integrations/providers/.
VIDEO_PROVIDER=wan
VOICE_PROVIDER=dashscope
MUSIC_PROVIDER=none

# HappyHorseProvider: generic vendor-agnostic adapter, isolated behind this config.
# Leave blank until you have a real provider (Runway, Kling, Veo, ElevenLabs, PlayHT...)
# to plug in - selecting "happyhorse" above without these set raises a clear startup
# error rather than silently failing.
HAPPYHORSE_BASE_URL=
HAPPYHORSE_API_KEY=

PROVIDER_POLL_INTERVAL_SECONDS=15
PROVIDER_POLL_TIMEOUT_SECONDS=600
